SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=false
ALLOWED_HOSTS=projects.innoprog.ru,127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://projects.innoprog.ru,https://app.innoprog.ru,https://innoprog.ru,https://www.innoprog.ru
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=https://projects.innoprog.ru,https://app.innoprog.ru,https://innoprog.ru,https://www.innoprog.ru

NAME=innoprog_projects
USER=innoprog_projects
PASSWORD=change-this-database-password
HOST=localhost
PORT=5432
DOMEN=https://projects.innoprog.ru

# Required for /api/lite/login/tg/ production login.
# TELEGRAM_BOT_TOKEN verifies Telegram WebApp initData.
# INNOPROG_PLATFORM_AUTH_SECRET must match the platform v1 auth token signing secret.
TELEGRAM_BOT_TOKEN=
INNOPROG_PLATFORM_AUTH_SECRET=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
ALLOW_UNVERIFIED_TELEGRAM_LOGIN=false
